{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReflexionKnowledgeItem",
  "type": "object",
  "required": [
    "pattern_id", "category", "product",
    "first_seen", "occurrences",
    "description", "root_cause", "prevention_rule"
  ],
  "properties": {
    "pattern_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Slug único do anti-pattern"
    },
    "category": {
      "type": "string",
      "enum": ["CI", "IR", "CA", "DT", "IA", "CC", "PE"]
    },
    "product": {
      "type": "string",
      "enum": [
        "ElysianLex", "CRM", "Ozzmosis",
        "AuroraCognitiveAssets", ".skills", "global"
      ]
    },
    "first_seen": { "type": "string", "format": "date" },
    "last_seen": { "type": "string", "format": "date" },
    "occurrences": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "root_cause": { "type": "string" },
    "prevention_rule": { "type": "string" },
    "example_fix": { "type": "string" },
    "related_os": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
