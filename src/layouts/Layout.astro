---
import '../styles/tokens.css';
import '../styles/globals.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="ElysianCorp — Sovereign Intelligence Architecture" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="stylesheet" href="https://use.typekit.net/iwz3xdf.css" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-black selection:bg-moss selection:text-ink halftone-noise antialiased">
		<slot />
		
		<style is:global>
			/* Critical Preloader / FOUC Protection */
			body {
				opacity: 0;
				animation: sovereignReveal 1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
			}

			@keyframes sovereignReveal {
				to { opacity: 1; }
			}

			/* Global Selection Style */
			::selection {
				background: var(--moss);
				color: var(--ink);
			}

			/* Prevent horizontal overflow without breaking Lenis/ScrollTrigger */
			html {
				overflow-x: hidden;
			}

			/* Hide Scrollbar for Clean UI */
			::-webkit-scrollbar {
				width: 4px;
			}
			::-webkit-scrollbar-track {
				background: transparent;
			}
			::-webkit-scrollbar-thumb {
				background: var(--moss);
				border-radius: 2px;
			}
		</style>
	</body>
</html>
