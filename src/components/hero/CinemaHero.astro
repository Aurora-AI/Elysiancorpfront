---
import { ScrambleBackground } from './ScrambleBackground';
import { IndustrialGrid } from './IndustrialGrid';
import { HeroContent } from './HeroContent';
import { ScramblePortrait } from '../fx/ScramblePortrait';

---

<section class="hero-container">
    <!-- UI Layer: Navigation handled by Layout/Index -->

    <!-- Layer 0: Scramble cipher strip — far background -->
    <div class="bg-layer opacity-40">
        <ScrambleBackground client:load />
    </div>

    <!-- Layer 1: Technical Grid -->
    <IndustrialGrid client:load />

    <!-- Layer 2: Scramble Portrait Scene -->
    <div class="main-scene">
        <div class="scramble-portrait-wrapper">
            <ScramblePortrait client:load />
        </div>
    </div>

    <!-- Layer 3: Hero Content & Branding -->
    <HeroContent client:load />

</section>

<style>
    .hero-container {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        background: var(--off-white);
    }

    .bg-layer {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    .scramble-portrait-wrapper {
        position: absolute;
        top: 50%;
        right: 8%;
        transform: translateY(-50%);
        width: 100%;
        max-width: 650px;
        z-index: 10;
        pointer-events: none;
        opacity: 0.9;
    }

    .main-scene {
        z-index: 5;
    }

</style>
