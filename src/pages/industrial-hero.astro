---
import HalideLanding from '../components/ui/HalideLanding';
import { ScrambleBackground } from '../components/hero/ScrambleBackground';
import MagneticCursor from '../components/cursor/MagneticCursor';
import '../styles/globals.css';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Liquid Semantic | Industrial Hero</title>
	</head>
	<body class="bg-[#050505] overflow-hidden">
		<main class="relative h-screen w-screen bg-[#050505]">
            <!-- Level 0: 3D Topographic Physics -->
            <div class="absolute inset-0 z-0 opacity-40">
                <HalideLanding client:load />
            </div>

            <!-- Level 1: Semantic Data Warp -->
            <div class="absolute inset-0 z-10">
                <ScrambleBackground client:only="react" />
            </div>

            <!-- Level 2: Editorial Typography -->
            <div class="absolute inset-0 z-20 flex flex-col items-center justify-center pointer-events-none">
                <div class="relative text-center px-6">
                    <span class="mono text-signal mb-2 block opacity-40 tracking-[0.4em] uppercase text-[10px]">
                        Project_Elysian // Industrial_v1
                    </span>
                    <h1 class="text-[14vw] font-display leading-[0.85] tracking-tighter text-white/90 uppercase mix-blend-difference">
                        ELYSIAN<br/>
                        <span class="opacity-40">CORP</span>
                    </h1>
                    <div class="mt-8 flex gap-8 items-center justify-center">
                        <div class="h-[1px] w-24 bg-black/20"></div>
                        <p class="mono text-[11px] opacity-50 max-w-xs uppercase leading-relaxed">
                            Implementing high-fidelity motion kinetics and semantic data displacement.
                        </p>
                        <div class="h-[1px] w-24 bg-black/20"></div>
                    </div>
                </div>
            </div>

            <!-- Level 3: Vignette & Noise -->
            <div class="absolute inset-0 z-30 pointer-events-none bg-radial-vignette opacity-60"></div>
            <div class="absolute inset-0 z-40 pointer-events-none grain-overlay mix-blend-overlay opacity-20"></div>

            <!-- Level 4: Magnetic Cursor -->
            <MagneticCursor client:only="react" />
        </main>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
	}
	body {
		margin: 0;
		padding: 0;
        cursor: none;
	}

    .bg-radial-vignette {
        background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.8) 100%);
    }

    .grain-overlay {
        background-image: url('https://grainy-gradients.vercel.app/noise.svg');
    }

    @font-face {
        font-family: 'DM Mono';
        src: url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap');
    }
</style>
