---
import HalideLanding from '../components/ui/HalideLanding';
import { HalideTopoHero as Counter } from '../components/ui/halide-topo-hero';
import '../styles/globals.css';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Halide S-Tier | ElysianCorp</title>
	</head>
	<body class="bg-[#0a0a0a]">
		<main>
            <HalideLanding client:load />
            
            {/* Embedded Counter for verification */}
            <div class="fixed bottom-12 left-12 z-50">
                <Counter client:load />
            </div>
        </main>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
	}
	body {
		margin: 0;
		padding: 0;
	}
</style>
