---
import Layout from '../layouts/Layout.astro';
import { GazeForensicHero } from '../components/hero/GazeForensicHero';
import { MagneticCursor } from '../components/cursor/MagneticCursor';
import { Header } from '../components/ui/Header';
import ProofSection from '../components/proof/ProofSection.astro';
import { GlobalNoiseCanvas } from '../components/sequence/GlobalNoiseCanvas';
---

<Layout title="ElysianCorp | Sovereign Intelligence Architecture">
	<GlobalNoiseCanvas client:only="react" />
	<MagneticCursor client:load />
	<Header client:load />

	<main>
		{/* SEÇÃO 1: STOP-MOTION ORIGINAL (GAZE FORENSIC V1.1.0) */}
		<GazeForensicHero client:load />

		{/* EVIDENCE LEDGER — interactive proof console (replaces cinematic sequence).
		    SequenceRigFull preserved in repo history / optional /cinema route. */}
		<ProofSection />
	</main>
</Layout>

<style>
	main {
		width: 100%;
		min-height: 100vh;
	}
</style>
