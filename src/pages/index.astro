---
import Layout from '../layouts/Layout.astro';
import { GazeForensicHero } from '../components/hero/GazeForensicHero';
import { MagneticCursor } from '../components/cursor/MagneticCursor';
import { TrustwareReality } from '../components/sections/TrustwareReality';
import { TrustwareArchitecture } from '../components/sections/TrustwareArchitecture';
import { TrustwarePortfolio } from '../components/sections/TrustwarePortfolio';
import { TrustwareProblem } from '../components/sections/TrustwareProblem';
import { TrustwareFounder } from '../components/sections/TrustwareFounder';
import { ForensicFooter } from '../components/sections/ForensicFooter';
import { Header } from '../components/ui/Header';
---

<Layout title="ElysianCorp | Sovereign Intelligence Architecture">
	<MagneticCursor client:load />
	<Header client:load />

	<main>
		{/* SEÇÃO 1: STOP-MOTION ORIGINAL (GAZE FORENSIC V1.1.0) */}
		<GazeForensicHero client:load />
		
		{/* SEÇÃO 2: PROVA DE REALIDADE (LIGHT) */}
		<TrustwareReality client:visible />

		{/* SEÇÃO 3: ARQUITETURA PROPRIETÁRIA (DARK) */}
		<TrustwareArchitecture client:visible />

		{/* SEÇÃO 4: PORTFÓLIO DE PRODUTOS (LIGHT) */}
		<TrustwarePortfolio client:visible />

		{/* SEÇÃO 5: DIFERENCIAIS SOBERANOS (DARK) */}
		<TrustwareProblem client:visible />

		{/* SEÇÃO 6: FOUNDER (LIGHT) */}
		<TrustwareFounder client:visible />

		{/* SEÇÃO 7: CTA FINAL (DARK) */}
		<ForensicFooter client:visible />
	</main>
</Layout>

<style>
	main {
		width: 100%;
		min-height: 100vh;
	}
</style>

